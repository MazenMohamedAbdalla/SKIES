<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.SKIES">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">
        <activity android:name="com.example.SKIES.CheckStatus"></activity>
        <activity android:name="com.example.SKIES.BankAccount" />
        <activity android:name="com.example.SKIES.SearchRound" />
        <activity android:name="com.example.SKIES.SearchOneWay" />
        <activity android:name="com.example.SKIES.RecoverPassword" />
        <activity android:name="com.example.SKIES.CreatAccount" />
        <activity android:name="com.example.SKIES.LoginActivity" />
        <activity android:name="com.example.SKIES.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>